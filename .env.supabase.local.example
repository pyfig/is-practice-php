# Supabase runtime configuration for Assignment 13
# Copy this file to .env.supabase.local and fill in your server-side credentials

# Get these values from your Supabase project dashboard/API keys:
# Project URL: https://supabase.com/dashboard/project/_/settings/api
# Server key: use the service_role key or a secret key with service_role claims

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Generate a random secret for cookie signing:
# openssl rand -base64 32
ASSIGNMENT13_AUTH_SECRET=change-this-to-a-random-string-min-32-characters
